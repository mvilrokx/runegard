#!/usr/bin/env bash
set -euo pipefail

echo "==> pre-push: linting"
uv run ruff check .

echo "==> pre-push: formatting check"
uv run ruff format --check .

echo "==> pre-push: type checking"
uv run ty check

echo "==> pre-push: full test suite"
uv run pytest tests/ -v

echo "==> pre-push: all checks passed"
